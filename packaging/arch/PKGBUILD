# Maintainer: Caleb Hendren <calebahendren@gmail.com>
# Packages the PyInstaller output (../../dist/PyMappr) built on Arch Linux.
# The CI workflow runs pyinstaller first, then makepkg in this directory.
pkgname=pymappr
pkgver=1.0.0
pkgrel=1
pkgdesc="Simple desktop mapping software: plot CSV points on offline basemaps, PNG export"
arch=('x86_64')
url="https://github.com/CalebHendren/PyMappr"
license=('MIT')
options=('!strip' '!debug')

package() {
    local dist="$startdir/../../dist/PyMappr"
    [ -d "$dist" ] || { echo "dist/PyMappr missing - run pyinstaller first"; return 1; }

    install -dm755 "$pkgdir/opt/pymappr" "$pkgdir/usr/bin" \
                   "$pkgdir/usr/share/applications"
    cp -a "$dist/." "$pkgdir/opt/pymappr/"
    ln -s /opt/pymappr/PyMappr "$pkgdir/usr/bin/pymappr"

    cat > "$pkgdir/usr/share/applications/pymappr.desktop" <<EOF
[Desktop Entry]
Type=Application
Name=PyMappr
Comment=Simple desktop mapping software
Exec=/opt/pymappr/PyMappr
Terminal=false
Categories=Education;Geography;Science;
EOF
}
